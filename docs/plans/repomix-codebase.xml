    if name in ("small-music", "small-sfx"):
        return StableAudioModel.from_pretrained(name, device=ACCEL_DEVICE)

    if name == "medium":
        if not HAS_CUDA:
            pytest.skip("Medium model requires a CUDA GPU — none detected")
