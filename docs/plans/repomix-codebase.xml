    background: radial-gradient(circle at 50% -20%, #1e1333 0%, var(--bg) 60%);
  }
}

@layer components {
  /* Fluid zoom for high-density - adjusts based on viewport height/width.
     --layout-zoom mirrors the zoom factor so `calc(... / var(--layout-zoom))`
     can pre-compensate for the rendering scale (e.g. so a child sized to fill
     `viewport - footer` actually renders at that size after zoom). */
  .dense-layout {
    --layout-zoom: 0.85;
    zoom: 0.85;
  }
  @media (min-width: 1440px) {
    .dense-layout {
      --layout-zoom: 0.95;
      zoom: 0.95;
    }
  }
  @media (min-width: 1920px) {
    .dense-layout {
      --layout-zoom: 1.1;
