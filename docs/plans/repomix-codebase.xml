    config = {"rank": _LORA_RANK, "alpha": _LORA_ALPHA, "adapter_type": "lora"}
    ckpt_path = tmp_path_factory.mktemp("lora") / "synthetic.safetensors"
    save_lora_safetensors(state_dict, config, ckpt_path)
